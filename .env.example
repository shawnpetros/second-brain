# Neon Postgres connection string (from Vercel dashboard → Storage)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# OpenAI API key (for embeddings + metadata extraction)
OPENAI_API_KEY=sk-...

# Clerk (OAuth 2.1 auth for MCP endpoint)
# Get these from Clerk Dashboard → API Keys
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional: Static API key for MCP clients that don't support OAuth 2.1 (e.g. Cursor)
# Generate with: openssl rand -base64 32
BRAIN_API_KEY=
