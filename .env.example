# Neon Postgres connection string (from Vercel dashboard → Storage)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# OpenAI API key (for embeddings + metadata extraction)
OPENAI_API_KEY=sk-...

# Bearer token to protect your brain's MCP endpoint
# Generate one: openssl rand -base64 32
# Leave empty in dev to allow unauthenticated access
BRAIN_API_KEY=
